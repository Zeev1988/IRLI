# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to "true" to skip all crawl and LLM calls and return stub data instead.
# No API keys required in this mode.
DEBUG_MODE=false

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose: "openai" (default) or "gemini"
LLM_PROVIDER=openai

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Required when LLM_PROVIDER=gemini
GEMINI_API_KEY=...

# ── Database ──────────────────────────────────────────────────────────────────
# Get this from Supabase → Project Settings → Database → Connection string (URI)
# Change the scheme from "postgresql" to "postgresql+asyncpg"
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.hcmlgwxvsdhgjlivyvex.supabase.co:5432/postgres

# ── Job Queue (optional) ──────────────────────────────────────────────────────
# When set, ingest/enrich API calls return 202 and run in background. Run worker: arq app.worker.WorkerSettings
REDIS_URL=redis://localhost:6379

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Hour (UTC) at which the daily re-crawl runs (default: 3 AM)
CRAWL_SCHEDULE_HOUR=3

# ── Link discovery (optional) ──────────────────────────────────────────────────
# Comma-separated regex patterns for lab URL paths. When set, only URLs matching
# at least one pattern pass to the LLM. E.g. for Technion/HUJI: ~[^/]+$,/people/
# LAB_PATH_PATTERNS=

# ── Ingestion concurrency ─────────────────────────────────────────────────────
# Max number of labs processed in parallel (default: 5)
INGEST_CONCURRENCY=5
