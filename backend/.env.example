# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to "true" to skip all crawl and LLM calls and return stub data instead.
# No API keys required in this mode.
DEBUG_MODE=false

# ── Embeddings (FastEmbed) ────────────────────────────────────────────────────
# Model name (default: BAAI/bge-large-en-v1.5). Dimension must match the model.
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose: "openai" (default) or "gemini"
LLM_PROVIDER=openai

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Required when LLM_PROVIDER=gemini
GEMINI_API_KEY=...

# ── Database ──────────────────────────────────────────────────────────────────
# Get this from Supabase → Project Settings → Database → Connection string (URI)
# Change the scheme from "postgresql" to "postgresql+asyncpg"
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.hcmlgwxvsdhgjlivyvex.supabase.co:5432/postgres

# ── Job Queue (optional) ──────────────────────────────────────────────────────
# When set, ingest/enrich API calls return 202 and run in background. Run worker: arq app.worker.WorkerSettings
REDIS_URL=redis://localhost:6379

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Hour (UTC) at which the daily re-crawl runs (default: 3 AM)
CRAWL_SCHEDULE_HOUR=3

# ── Link discovery (optional) ──────────────────────────────────────────────────
# Comma-separated regex patterns for lab URL paths. When set, only URLs matching
# at least one pattern pass to the LLM. E.g. for Technion/HUJI: ~[^/]+$,/people/
# LAB_PATH_PATTERNS=

# ── Crawl cache ───────────────────────────────────────────────────────────────
# When true (default), Crawl4AI caches pages locally. Set false for debugging.
# CRAWL_CACHE_ENABLED=true

# ── Crawl identity (robots.txt compliance) ────────────────────────────────────
# User-Agent sent with requests. Set CRAWL_CONTACT_EMAIL for admin contact, or
# CRAWL_USER_AGENT to override the full string. Default respects robots.txt.
# CRAWL_CONTACT_EMAIL=your-email@example.com
# CRAWL_USER_AGENT=IRLI/1.0 (+https://github.com; mailto:you@example.com)

# ── OpenAlex (metrics enrichment) ───────────────────────────────────────────
# Optional: get free key at openalex.org/settings/api for $1/day credits, higher limits.
# OA_API_KEY=...
# OA_MAILTO=your-email@example.com
# OA_RATE_LIMIT_DELAY=0.2

# ── Ingestion concurrency ─────────────────────────────────────────────────────
# Max number of labs processed in parallel (default: 5)
INGEST_CONCURRENCY=5

# Skip crawl+extract if lab already exists and was crawled within N days (0 = disabled)
# SKIP_RECENT_CRAWLS_DAYS=7
